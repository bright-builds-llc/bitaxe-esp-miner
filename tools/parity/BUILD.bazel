load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_test")

rust_binary(
    name = "report",
    srcs = ["src/main.rs"],
    crate_name = "bitaxe_parity",
    data = ["//scripts:verify_reference_clean"],
    edition = "2021",
    deps = [
        "@crates//:anyhow",
        "@crates//:camino",
        "@crates//:clap",
        "@crates//:serde",
        "@crates//:serde_json",
    ],
    visibility = ["//visibility:public"],
)

rust_test(
    name = "tests",
    crate = ":report",
)
