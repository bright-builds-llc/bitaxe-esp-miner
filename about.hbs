<!--
Phase 7 cargo-about 0.9.0 template for Cargo dependency licenses.
This generated Cargo report is one input to PROVENANCE.md review.
It does not cover GPL-covered upstream reference material, Bazel/rules inputs,
ESP-IDF components, flashing tools, static assets, or release artifacts.
-->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>Bitaxe Rust Firmware Cargo Dependency Licenses</title>
    <style>
        body {
            color: #18212f;
            background: #f8fafc;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            line-height: 1.5;
            margin: 0;
        }

        main {
            max-width: 960px;
            margin: 0 auto;
            padding: 32px 20px;
        }

        h1, h2, h3, h4 {
            color: #111827;
        }

        a {
            color: #0f5fcb;
        }

        .notice {
            border-left: 4px solid #a12b2b;
            background: #fff7ed;
            padding: 12px 16px;
            margin: 16px 0 28px;
        }

        .licenses-overview,
        .license-used-by {
            padding-left: 20px;
        }

        .licenses-list {
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .license {
            border-top: 1px solid #d1d5db;
            padding: 20px 0;
        }

        .license-text {
            max-height: 240px;
            overflow: auto;
            white-space: pre-wrap;
            background: #ffffff;
            border: 1px solid #d1d5db;
            padding: 12px;
        }
    </style>
</head>
<body>
<main>
    <h1>Bitaxe Rust Firmware Cargo Dependency Licenses</h1>
    <p>
        Generated by cargo-about for the Cargo workspace dependency graph.
        Accepted licenses are governed by about.toml and PROVENANCE.md.
    </p>
    <p class="notice">
        This report is Cargo-only. Non-Cargo release inputs, GPL-covered upstream
        reference material, static assets, and firmware release artifacts require
        the separate release inventory and provenance manifest.
    </p>

    <h2>Overview of licenses</h2>
    <ul class="licenses-overview">
        {{#each overview}}
        <li><a href="#{{id}}">{{name}}</a> ({{count}})</li>
        {{/each}}
    </ul>

    <h2>License text and crates</h2>
    <ul class="licenses-list">
        {{#each licenses}}
        <li class="license">
            {{#if first_of_kind}}
            <h3 id="{{id}}">{{name}}</h3>
            {{/if}}
            <h4 id="{{id}}-{{@index}}">{{name}}</h4>
            <h5>Used by</h5>
            <ul class="license-used-by">
                {{#each used_by}}
                <li>
                    <a href="{{#if crate.repository}}{{crate.repository}}{{else}}https://crates.io/crates/{{crate.name}}{{/if}}">
                        {{crate.name}} {{crate.version}}
                    </a>
                </li>
                {{/each}}
            </ul>
            <pre class="license-text">{{text}}</pre>
        </li>
        {{/each}}
    </ul>
</main>
</body>
</html>
